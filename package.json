{
  "name": "@pajama-studio/prefab-studio",
  "version": "0.1.2",
  "description": "Domain-agnostic prefab editor for the Pajama Studio prefab framework: a headless editing core (ops, selection, undo/redo, store persistence) with React bindings. Bring your own viewport; domain packs contribute inspectors.",
  "license": "MIT",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": [
    "dist",
    "README.md"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.build.json",
    "test": "vitest run"
  },
  "dependencies": {
    "@pajama-studio/prefab-core": "^0.3.2"
  },
  "peerDependencies": {
    "react": ">=18"
  },
  "devDependencies": {
    "@types/react": "^19.0.0",
    "react": "^19.0.0",
    "typescript": "^5.6.0",
    "vitest": "^3.0.0"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/pajama-studio/prefab-studio.git"
  },
  "homepage": "https://github.com/pajama-studio/prefab-studio#readme",
  "publishConfig": {
    "access": "public"
  }
}
